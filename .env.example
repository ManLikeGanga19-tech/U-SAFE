# ─────────────────────────────────────────────────────────────
# U-SAFE KE — environment template. Copy to .env for local dev.
# Never commit the real .env.
# ─────────────────────────────────────────────────────────────

# ---- Core ----
ENVIRONMENT=development
PROJECT_NAME=U-SAFE KE

# ---- API ----
API_PORT=8080
# CORS: comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ---- Auth ----
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-in-production-please-32bytes-min
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# ---- Database (Postgres) ----
POSTGRES_USER=usafe
POSTGRES_PASSWORD=usafe_dev_pw
POSTGRES_DB=usafe
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Host-side port mapping (avoid clashes with other local stacks)
POSTGRES_HOST_PORT=5433

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6381

# ---- Object storage (S3-compatible: MinIO in dev, R2 in prod) ----
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9002
S3_REGION=us-east-1
S3_ACCESS_KEY=usafe_minio
S3_SECRET_KEY=usafe_minio_pw
S3_BUCKET=usafe-media
MINIO_API_HOST_PORT=9002
MINIO_CONSOLE_HOST_PORT=9003

# ---- Seed admin (created on first migrate/seed) ----
FIRST_ADMIN_EMAIL=admin@u-safe.co.ke
FIRST_ADMIN_PASSWORD=ChangeMe123!

# ---- M-Pesa (Safaricom Daraja) ----
# mock = local simulator (no real Daraja); sandbox/live need real credentials + public callback URL
MPESA_MODE=mock
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://localhost:8080/api/v1/payments/mpesa/callback
MPESA_MOCK_DELAY=6

# ---- ngrok tunnel (only for local sandbox/live M-Pesa testing) ----
# Get a free authtoken + one static domain at https://dashboard.ngrok.com
NGROK_AUTHTOKEN=
NGROK_DOMAIN=          # e.g. usafe-dev.ngrok-free.app  (no https://)

# ---- Frontend ----
WEB_PORT=3000
ADMIN_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:8080
